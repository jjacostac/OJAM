# ============================================================
# OJAM — Variables de entorno (plantilla)
# Copia este archivo como `backend/.env` para desarrollo local.
# En producción, configúralas en el panel de Render (backend).
# El frontend en Cloudflare Pages no usa .env: sus valores públicos
# van en frontend/js/config.js. NUNCA subas valores reales.
# ============================================================

# --- Supabase (Proyecto > Settings > API) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
# La service role key SOLO vive en el backend. Jamás en el frontend.
SUPABASE_SERVICE_ROLE_KEY=

# --- Administración ---
# Correos autorizados para el panel admin, separados por coma.
# Deben existir como usuarios en Supabase Auth.
ADMIN_EMAIL=

# --- URLs públicas ---
# URL(s) del frontend autorizadas para CORS, separadas por coma.
# Empieza con la URL temporal gratuita; cuando el dominio .org esté
# listo, AGREGA el dominio aquí (no borres la temporal hasta migrar)
# y redespliega. Sin cambios de código. Ver docs/dominio.md.
PUBLIC_URL=http://localhost:5173

# --- Backend ---
PORT=8787
