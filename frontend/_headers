# Cabeceras para Cloudflare Pages (y compatible con Netlify).
# Cloudflare lee este archivo desde el directorio publicado (frontend/).

# El service worker no se cachea: controla la actualización del resto.
/sw.js
  Cache-Control: no-cache

# Librerías con hash de versión: caché larga e inmutable.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Assets propios (logos, íconos, geojson): una semana.
/assets/*
  Cache-Control: public, max-age=604800

# Endurecimiento básico para todo el sitio.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
